{
  "manifest_version": 3,
  "name": "Getgems Marketplace Marker",
  "version": "1.6.0",
  "description": "Marks NFT listings with Getgems or Fragment logo based on marketplace. Helps identify listing source and associated fees.",
  "author": "NFT Tools",
  "homepage_url": "https://github.com/solana-boy/getgems-marker",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "action": {
    "default_popup": "index.html"
  },
  "host_permissions": [
    "https://getgems.io/*",
    "https://web.telegram.org/*",
    "https://toncenter.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://getgems.io/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://web.telegram.org/*"],
      "js": ["telegram-auth-capture.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "injected.js",
        "getgems.svg",
        "fragment.svg",
        "gift-satellite-embed.html",
        "gift-satellite-embed.css",
        "gift-satellite-embed.js"
      ],
      "matches": ["https://getgems.io/*"]
    }
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "minimum_chrome_version": "110"
}
